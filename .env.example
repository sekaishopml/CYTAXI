# ===========================================
# CYTAXI - Variables de Entorno
# ===========================================

# ===========================================
# BASE DE DATOS
# ===========================================
DATABASE_URL=postgresql://cytaxi:cytaxi_secret@localhost:5433/cytaxi
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=cytaxi
DATABASE_USER=cytaxi
DATABASE_PASSWORD=cytaxi_secret

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6380
REDIS_HOST=localhost
REDIS_PORT=6380

# ===========================================
# NATS
# ===========================================
NATS_URL=nats://localhost:4223
NATS_CLUSTER_ID=cytaxi-cluster
NATS_CLIENT_ID=cytaxi-service

# ===========================================
# BOT WHATSAPP
# ===========================================
WHATSAPP_PHONE_NUMBER=+593990000000
WHATSAPP_BOT_NAME=CYTAXI Bot

# ===========================================
# GEOCODER
# ===========================================
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=CYTAXI/1.0

# ===========================================
# NOTIFICATIONS (Firebase - opcional)
# ===========================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ===========================================
# SERVIDORES
# ===========================================
BOT_SERVICE_PORT=3001
RIDE_SERVICE_PORT=3002
DRIVER_SERVICE_PORT=3003
MATCHING_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
GEOCODER_SERVICE_PORT=3006
DASHBOARD_PORT=3000
APP_PORT=3007
PWA_PORT=3008

# ===========================================
# MAPAS
# ===========================================
DEFAULT_MAP_CENTER_LAT=-0.1807
DEFAULT_MAP_CENTER_LON=-78.4678
DEFAULT_MAP_ZOOM=13

# ===========================================
# TARIFAS
# ===========================================
BASE_FARE=1.50
PER_KM_RATE=0.50
PER_MINUTE_RATE=0.10
MINIMUM_FARE=2.50
